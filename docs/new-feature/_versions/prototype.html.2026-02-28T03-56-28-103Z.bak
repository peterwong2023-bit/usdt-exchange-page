    <script>
        let isDragging = false;
        let dragElement = null;
        let dragOffset = { x: 0, y: 0 };
        let selectedTemplate = null;
        let isRefreshPaused = false;

        // 菜单下拉
        function toggleDropdown() {
            const dropdown = document.getElementById('menuDropdown');
            dropdown.classList.toggle('show');
        }

        // 关闭下拉菜单
        document.addEventListener('click', (e) => {
            const dropdown = document.getElementById('menuDropdown');
            if (!e.target.closest('.menu-item') && !e.target.closest('.menu-dropdown')) {
                dropdown.classList.remove('show');
            }
        });

        // 拖拽功能
        function startDrag(e, elementId) {
            e.preventDefault();
            isDragging = true;
            dragElement = document.getElementById(elementId);
            
            const rect = dragElement.getBoundingClientRect();
            dragOffset.x = e.clientX - rect.left;
            dragOffset.y = e.clientY - rect.top;
            
            dragElement.classList.add('dragging');
            dragElement.style.zIndex = '999';
        }

        document.addEventListener('mousemove', (e) => {
            if (isDragging && dragElement) {
                const x = e.clientX - dragOffset.x;
                const y = e.clientY - dragOffset.y;
                
                dragElement.style.left = Math.max(0, x) + 'px';
                dragElement.style.top = Math.max(28, y) + 'px';
            }
        });

        document.addEventListener('mouseup', () => {
            if (isDragging && dragElement) {
                dragElement.classList.remove('dragging');
                dragElement.style.zIndex = '';
                isDragging = false;
                dragElement = null;
            }
        });

        // 便签操作
        function closeSticky(id) {
            const element = document.getElementById(id);
            element.style.transform = 'scale(0.8)';
            element.style.opacity = '0';
            setTimeout(() => {
                element.style.display = 'none';
            }, 200);
        }

        function refreshSticky(id) {
            const btn = event.target;
            btn.style.transform = 'rotate(360deg)';
            setTimeout(() => {
                btn.style.transform = '';
            }, 500);
        }

        function openSettings(id) {
            alert('打开便签设置：' + id);
        }

        function focusSticky(id) {
            const element = document.getElementById(id);
            element.style.zIndex = '100';
            element.style.transform = 'scale(1.02)';
            setTimeout(() => {
                element.style.transform = '';
                element.style.zIndex = '';
            }, 200);
            closeSearch();
        }

        // 模态框
        function openNewModal() {
            document.getElementById('newStickyModal').classList.add('show');
            document.getElementById('menuDropdown').classList.remove('show');
        }

        function closeModal(id) {
            document.getElementById(id).classList.remove('show');
            selectedTemplate = null;
            document.querySelectorAll('.template-card').forEach(card => {
                card.classList.remove('selected');
            });
        }

        function selectTemplate(type) {
            selectedTemplate = type;
            document.querySelectorAll('.template-card').forEach(card => {
                card.classList.remove('selected');
            });
            event.currentTarget.classList.add('selected');
        }

        function createSticky() {
            if (!selectedTemplate) {
                alert('请选择一个模板');
                return;
            }
            
            alert('创建便签：' + selectedTemplate);
            closeModal('newStickyModal');
        }

        // 全局搜索
        function openSearch() {
            document.getElementById('searchOverlay').classList.add('show');
            document.getElementById('searchInput').focus();
            document.getElementById('menuDropdown').classList.remove('show');
        }

        function closeSearch() {
            document.getElementById('searchOverlay').classList.remove('show');
            document.getElementById('searchInput').value = '';
        }

        function searchStickies(query) {
            // 搜索逻辑
        }

        // 键盘快捷键
        document.addEventListener('keydown', (e) => {
            if (e.metaKey && e.key === 'k') {
                e.preventDefault();
                openSearch();
            }
            if (e.key === 'Escape') {
                closeSearch();
                closeModal('newStickyModal');
            }
        });

        // 刷新控制
        function toggleRefresh() {
            isRefreshPaused = !isRefreshPaused;
            const icon = document.getElementById('refreshIcon');
            const text = document.getElementById('refreshText');
            
            if (isRefreshPaused) {
                icon.className = 'fas fa-play';
                text.textContent = '恢复全部刷新';
            } else {
                icon.className = 'fas fa-pause';
                text.textContent = '暂停全部刷新';
            }
            
            document.getElementById('menuDropdown').classList.remove('show');
        }

        // AI 整理
        function aiTidy() {
            const btn = event.target;
            const originalText = btn.innerHTML;
            
            btn.innerHTML = '<i class="fas fa-spinner fa-spin" style="margin-right: 4px;"></i>整理中...';
            btn.disabled = true;
            
            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.disabled = false;
                alert('AI 整理完成！');
            }, 2000);
        }

        // 其他功能
        function openAlertCenter() {
            document.getElementById('alertCenterModal').classList.add('show');
            document.getElementById('menuDropdown').classList.remove('show');
        }

        function openKeyManager() {
            alert('打开 Key 管理');
            document.getElementById('menuDropdown').classList.remove('show');
        }

        // 便签状态处理
        function fixKey(stickyId) {
            document.getElementById('keyWizardModal').classList.add('show');
        }

        function retrySticky(stickyId) {
            const btn = event.target;
            btn.textContent = '重试中...';
            btn.disabled = true;
            setTimeout(() => {
                btn.textContent = '重试';
                btn.disabled = false;
            }, 2000);
        }

        function switchProvider(stickyId) {
            document.getElementById('providerSwitchModal').classList.add('show');
        }

        // 告警中心功能
        function filterAlerts(type) {
            document.querySelectorAll('.alert-filter-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
        }

        function selectAlert(element) {
            document.querySelectorAll('.alert-item').forEach(item => item.classList.remove('active'));
            element.classList.add('active');
        }

        function markAsRead() {
            alert('已标记为已查看');
        }

        function goToSticky(stickyId) {
            closeModal('alertCenterModal');
            focusSticky(stickyId);
        }

        function clearAlertHistory(stickyId) {
            if (confirm('确定要清空该便签的告警历史吗？')) {
                alert('告警历史已清空');
            }
        }

        // Key 向导功能
        let currentKeyStep = 1;
        let selectedProvider = null;

        function selectProvider(provider) {
            selectedProvider = provider;
            document.querySelectorAll('.provider-card').forEach(card => card.classList.remove('selected'));
            event.currentTarget.classList.add('selected');
        }

        function keyWizardNext() {
            if (currentKeyStep === 1) {
                if (!selectedProvider) {
                    alert('请选择一个数据源');
                    return;
                }
                document.getElementById('keyStep1').style.display = 'none';
                document.getElementById('keyStep2').style.display = 'block';
                document.getElementById('keyBackBtn').style.display = 'inline-block';
                document.getElementById('keyNextBtn').textContent = '验证';
                currentKeyStep = 2;
            } else if (currentKeyStep === 2) {
                const apiKey = document.getElementById('apiKey').value;
                if (!apiKey.trim()) {
                    alert('请输入 API Key');
                    return;
                }
                document.getElementById('keyStep2').style.display = 'none';
                document.getElementById('keyStep3').style.display = 'block';
                document.getElementById('keyNextBtn').style.display = 'none';
                currentKeyStep = 3;
                
                // 模拟验证过程
                setTimeout(() => {
                    document.getElementById('keyTestResult').textContent = 'API Key 验证成功';
                    document.getElementById('keyTestDesc').textContent = '连接正常，可以开始使用';
                    document.getElementById('keyTestDetails').innerHTML = `
                        <div style="color: var(--success); font-size: 48px; margin-bottom: 12px;">
                            <i class="fas fa-check-circle"></i>
                        </div>
                        <div style="color: var(--text-primary); font-size: 13px; font-weight: 600;">
                            ${selectedProvider} API 连接成功
                        </div>
                    `;
                    document.getElementById('keyNextBtn').style.display = 'inline-block';
                    document.getElementById('keyNextBtn').textContent = '完成';
                }, 2000);
            } else {
                closeModal('keyWizardModal');
                resetKeyWizard();
            }
        }

        function keyWizardBack() {
            if (currentKeyStep === 2) {
                document.getElementById('keyStep2').style.display = 'none';
                document.getElementById('keyStep1').style.display = 'block';
                document.getElementById('keyBackBtn').style.display = 'none';
                document.getElementById('keyNextBtn').textContent = '下一步';
                currentKeyStep = 1;
            }
        }

        function resetKeyWizard() {
            currentKeyStep = 1;
            selectedProvider = null;
            document.getElementById('keyStep1').style.display = 'block';
            document.getElementById('keyStep2').style.display = 'none';
            document.getElementById('keyStep3').style.display = 'none';
            document.getElementById('keyBackBtn').style.display = 'none';
            document.getElementById('keyNextBtn').style.display = 'inline-block';
            document.getElementById('keyNextBtn').textContent = '下一步';
            document.getElementById('apiKey').value = '';
            document.getElementById('secretKey').value = '';
            document.querySelectorAll('.provider-card').forEach(card => card.classList.remove('selected'));
        }

        // Provider 切换功能
        function confirmProviderSwitch() {
            closeModal('providerSwitchModal');
            alert('数据源切换成功，正在重新获取数据...');
        }

        // 初始化
        document.addEventListener('DOMContentLoaded', () => {
            // 模拟数据更新
            setInterval(() => {
                if (!isRefreshPaused) {
                    // 更新时间戳
                    document.querySelectorAll('.sticky-footer span').forEach((span, index) => {
                        if (span.textContent.includes('更新于')) {
                            const times = ['刚刚', '1 分钟前', '2 分钟前', '3 分钟前', '5 分钟前'];
                            span.textContent = '更新于 ' + times[Math.floor(Math.random() * times.length)];
                        }
                    });
                }
            }, 10000);
        });
    </script>
</body>
</html>