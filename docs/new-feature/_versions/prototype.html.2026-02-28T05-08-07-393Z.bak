    <!-- Key 向导模态框 -->
    <div class="modal-overlay" id="keyWizardModal">
        <div class="modal">
            <div class="modal-header">
                <h2 class="modal-title">API Key 向导</h2>
            </div>
            <div class="modal-body">
                <div style="text-align: center; margin-bottom: 24px;">
                    <div style="font-size: 16px; color: #fff; margin-bottom: 8px;">配置 Binance API Key</div>
                    <div style="font-size: 14px; color: rgba(255,255,255,0.6);">请前往 Binance 获取您的 API Key</div>
                </div>
                
                <div class="settings-item">
                    <label class="settings-label">API Key</label>
                    <input type="text" placeholder="粘贴您的 API Key" style="width: 100%; padding: 12px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: #fff; font-family: 'JetBrains Mono', monospace;">
                </div>
                
                <div class="settings-item">
                    <label class="settings-label">Secret Key</label>
                    <input type="password" placeholder="粘贴您的 Secret Key" style="width: 100%; padding: 12px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: #fff; font-family: 'JetBrains Mono', monospace;">
                </div>
                
                <div style="background: rgba(37, 99, 235, 0.1); border: 1px solid rgba(37, 99, 235, 0.3); border-radius: 8px; padding: 12px; font-size: 13px; color: rgba(255,255,255,0.8);">
                    <i class="fas fa-info-circle" style="margin-right: 8px; color: var(--primary);"></i>
                    您的 API Key 仅存储在本地，不会上传到任何服务器
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn secondary" onclick="closeModal('keyWizardModal')">取消</button>
                <button class="btn primary" onclick="testApiKey()">测试并保存</button>
            </div>
        </div>
    </div>

    <script>
        // 全局变量
        let isDragging = false;
        let isResizing = false;
        let dragElement = null;
        let resizeElement = null;
        let dragOffset = { x: 0, y: 0 };
        let selectedTemplate = null;
        let currentSettingsSticky = null;
        let globalRefreshPaused = false;

        // 菜单栏功能
        function toggleDropdown() {
            const dropdown = document.getElementById('menuDropdown');
            dropdown.classList.toggle('show');
        }

        function toggleRefresh() {
            globalRefreshPaused = !globalRefreshPaused;
            const icon = document.getElementById('refreshIcon');
            const text = document.getElementById('refreshText');
            
            if (globalRefreshPaused) {
                icon.className = 'fas fa-play';
                text.textContent = '恢复全部刷新';
                // 更新所有便签状态
                document.querySelectorAll('.sticky-window').forEach(sticky => {
                    const footer = sticky.querySelector('.sticky-footer .footer-status span:last-child');
                    if (footer) footer.textContent = '已暂停';
                });
            } else {
                icon.className = 'fas fa-pause';
                text.textContent = '暂停全部刷新';
                // 恢复所有便签状态
                document.querySelectorAll('.sticky-window').forEach(sticky => {
                    const footer = sticky.querySelector('.sticky-footer .footer-status span:last-child');
                    if (footer) footer.textContent = '正常';
                });
            }
        }

        // 拖拽和缩放功能
        function startDrag(e, id) {
            if (e.target.closest('.sticky-actions') || e.target.closest('.traffic-lights') || e.target.closest('.resize-handle')) {
                return;
            }
            
            isDragging = true;
            dragElement = document.getElementById(id);
            
            const rect = dragElement.getBoundingClientRect();
            dragOffset.x = e.clientX - rect.left;
            dragOffset.y = e.clientY - rect.top;
            
            dragElement.classList.add('dragging');
            focusSticky(dragElement);
            
            e.preventDefault();
        }

        function startResize(e, element) {
            if (element.classList.contains('locked')) {
                return;
            }
            
            isResizing = true;
            resizeElement = element;
            
            e.preventDefault();
            e.stopPropagation();
        }

        // 全局事件监听
        document.addEventListener('mousemove', function(e) {
            if (isDragging && dragElement) {
                const x = e.clientX - dragOffset.x;
                const y = e.clientY - dragOffset.y;
                
                dragElement.style.left = Math.max(0, Math.min(x, window.innerWidth - dragElement.offsetWidth)) + 'px';
                dragElement.style.top = Math.max(32, Math.min(y, window.innerHeight - dragElement.offsetHeight)) + 'px';
            }
            
            if (isResizing && resizeElement) {
                const rect = resizeElement.getBoundingClientRect();
                const newWidth = Math.max(240, e.clientX - rect.left);
                const newHeight = Math.max(160, e.clientY - rect.top);
                
                resizeElement.style.width = newWidth + 'px';
                resizeElement.style.height = newHeight + 'px';
            }
        });

        document.addEventListener('mouseup', function() {
            if (isDragging && dragElement) {
                dragElement.classList.remove('dragging');
                isDragging = false;
                dragElement = null;
            }
            
            if (isResizing && resizeElement) {
                isResizing = false;
                resizeElement = null;
            }
        });

        // 便签窗口功能
        function focusSticky(element) {
            document.querySelectorAll('.sticky-window').forEach(w => w.classList.remove('focused'));
            element.classList.add('focused');
        }

        function closeSticky(id) {
            const element = document.getElementById(id);
            element.style.display = 'none';
        }

        function refreshSticky(id) {
            const btn = document.querySelector(`#${id} .sticky-action-btn i.fa-sync-alt`);
            btn.style.animation = 'spin 1s linear';
            setTimeout(() => btn.style.animation = '', 1000);
        }

        // 更多菜单功能
        function toggleMoreMenu(btn) {
            const menu = btn.nextElementSibling;
            document.querySelectorAll('.more-menu').forEach(m => {
                if (m !== menu) m.classList.remove('show');
            });
            menu.classList.toggle('show');
        }

        function togglePin(id) {
            const checkmark = document.getElementById(id.replace('-sticky', '-pin-check'));
            const isVisible = checkmark.style.display !== 'none';
            checkmark.style.display = isVisible ? 'none' : 'inline';
            
            // 关闭菜单
            document.querySelectorAll('.more-menu').forEach(m => m.classList.remove('show'));
        }

        function toggleLock(id) {
            const element = document.getElementById(id);
            const checkmark = document.getElementById(id.replace('-sticky', '-lock-check'));
            const isLocked = element.classList.contains('locked');
            
            if (isLocked) {
                element.classList.remove('locked');
                checkmark.style.display = 'none';
            } else {
                element.classList.add('locked');
                checkmark.style.display = 'inline';
            }
            
            // 关闭菜单
            document.querySelectorAll('.more-menu').forEach(m => m.classList.remove('show'));
        }

        function copySticky(id) {
            alert('便签已复制');
            document.querySelectorAll('.more-menu').forEach(m => m.classList.remove('show'));
        }

        function adjustOpacity(id) {
            const element = document.getElementById(id);
            const currentOpacity = parseFloat(element.style.opacity) || 1;
            const newOpacity = currentOpacity === 1 ? 0.7 : currentOpacity === 0.7 ? 0.4 : 1;
            element.style.opacity = newOpacity;
            
            document.querySelectorAll('.more-menu').forEach(m => m.classList.remove('show'));
        }

        // 设置面板功能
        function openSettings(id) {
            currentSettingsSticky = id;
            const popover = document.getElementById('stickySettingsPopover');
            const sticky = document.getElementById(id);
            const rect = sticky.getBoundingClientRect();
            
            popover.style.display = 'block';
            popover.style.left = (rect.right + 10) + 'px';
            popover.style.top = rect.top + 'px';
            
            // 确保不超出屏幕
            if (rect.right + 370 > window.innerWidth) {
                popover.style.left = (rect.left - 370) + 'px';
            }
        }

        function closeSettingsPopover() {
            document.getElementById('stickySettingsPopover').style.display = 'none';
            currentSettingsSticky = null;
        }

        function switchSettingsTab(tab, contentId) {
            // 切换标签
            document.querySelectorAll('.settings-tab').forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            
            // 切换内容
            document.querySelectorAll('.settings-content').forEach(c => c.classList.remove('active'));
            document.getElementById(contentId + '-content').classList.add('active');
        }

        function toggleSwitch(switchEl) {
            switchEl.classList.toggle('active');
        }

        // Footer 修复功能
        function fixKey(id) {
            openKeyWizard();
        }

        function switchProvider(id) {
            alert('切换数据源');
        }

        // 模态框功能
        function openNewModal() {
            document.getElementById('newStickyModal').classList.add('show');
            document.getElementById('menuDropdown').classList.remove('show');
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('show');
            selectedTemplate = null;
            document.querySelectorAll('.template-card').forEach(card => card.classList.remove('selected'));
            document.getElementById('createBtn').disabled = true;
        }

        function selectTemplate(card, type) {
            document.querySelectorAll('.template-card').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            selectedTemplate = type;
            document.getElementById('createBtn').disabled = false;
        }

        function createSticky() {
            if (!selectedTemplate) return;
            
            alert(`创建 ${selectedTemplate} 便签`);
            closeModal('newStickyModal');
        }

        // 搜索功能
        function openSearch() {
            document.getElementById('searchOverlay').classList.add('show');
            document.getElementById('menuDropdown').classList.remove('show');
            document.querySelector('.search-input').focus();
        }

        function searchStickies(query) {
            // 简单的搜索演示
            const items = document.querySelectorAll('.search-item');
            items.forEach(item => {
                const name = item.querySelector('.search-item-name').textContent.toLowerCase();
                const desc = item.querySelector('.search-item-desc').textContent.toLowerCase();
                const match = name.includes(query.toLowerCase()) || desc.includes(query.toLowerCase());
                item.style.display = match ? 'flex' : 'none';
            });
        }

        function focusSearchResult(id) {
            const element = document.getElementById(id);
            if (element) {
                focusSticky(element);
                element.style.border = '2px solid var(--primary)';
                setTimeout(() => element.style.border = '', 2000);
            }
            document.getElementById('searchOverlay').classList.remove('show');
        }

        // Key 向导
        function openKeyWizard() {
            document.getElementById('keyWizardModal').classList.add('show');
            closeSettingsPopover();
        }

        function testApiKey() {
            alert('API Key 测试成功！');
            closeModal('keyWizardModal');
            
            // 更新便签状态
            if (currentSettingsSticky) {
                const footer = document.querySelector(`#${currentSettingsSticky} .footer-status`);
                const indicator = footer.querySelector('.health-indicator');
                const status = footer.querySelector('span:last-child');
                const btn = footer.querySelector('.footer-action-btn');
                
                indicator.className = 'health-indicator';
                status.textContent = '正常';
                if (btn) btn.style.display = 'none';
            }
        }

        function testConnection() {
            alert('连接测试成功！');
        }

        // 其他功能
        function openAlertCenter() {
            alert('打开告警中心');
            document.getElementById('menuDropdown').classList.remove('show');
        }

        function openKeyManager() {
            alert('打开 Key 管理');
            document.getElementById('menuDropdown').classList.remove('show');
        }

        function aiOrganize(id) {
            const textarea = document.querySelector(`#${id} .memo-textarea`);
            textarea.value = `# 产品评审会议纪要

## 会议概要
- **时间**: 2024年1月15日
- **参与人员**: 产品团队
- **主题**: AI Sticky v1.0 功能确认

## 决策事项
1. ✅ 确认 AI Sticky v1.0 功能范围
2. ✅ 讨论便签模板设计
3. ✅ 确定 API Key 管理策略

## 下一步行动
- [ ] 下周开始开发
- [ ] 准备技术方案文档
- [ ] 设计评审排期`;
        }

        function saveNote(id) {
            alert('记录已保存');
        }

        // 键盘快捷键
        document.addEventListener('keydown', function(e) {
            if (e.metaKey && e.key === 'k') {
                e.preventDefault();
                openSearch();
            }
            
            if (e.key === 'Escape') {
                document.querySelectorAll('.modal-overlay, .search-overlay').forEach(overlay => {
                    overlay.classList.remove('show');
                });
                closeSettingsPopover();
                document.querySelectorAll('.more-menu').forEach(m => m.classList.remove('show'));
            }
        });

        // 点击外部关闭
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.menu-dropdown') && !e.target.closest('.menu-item')) {
                document.getElementById('menuDropdown').classList.remove('show');
            }
            
            if (!e.target.closest('.more-menu') && !e.target.closest('.sticky-action-btn')) {
                document.querySelectorAll('.more-menu').forEach(m => m.classList.remove('show'));
            }
            
            if (!e.target.closest('.settings-popover') && !e.target.closest('.sticky-action-btn')) {
                closeSettingsPopover();
            }
        });

        // 初始化
        document.addEventListener('DOMContentLoaded', function() {
            console.log('AI Sticky 原型已加载');
            
            // 添加旋转动画
            const style = document.createElement('style');
            style.textContent = `
                @keyframes spin {
                    from { transform: rotate(0deg); }
                    to { transform: rotate(360deg); }
                }
            `;
            document.head.appendChild(style);
        });
    </script>
</body>
</html>