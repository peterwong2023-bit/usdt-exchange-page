                    </div>
                    <div class="template-card" onclick="selectTemplate(this, 'stock')">
                        <div class="template-icon stock">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <div class="template-name">股票监控</div>
                        <div class="template-desc">美股港股实时数据</div>
                    </div>
                    <div class="template-card" onclick="selectTemplate(this, 'traffic')">
                        <div class="template-icon traffic">
                            <i class="fas fa-route"></i>
                        </div>
                        <div class="template-name">交通路况</div>
                        <div class="template-desc">导航和ETA预测</div>
                    </div>
                    <div class="template-card" onclick="selectTemplate(this, 'weather')">
                        <div class="template-icon weather">
                            <i class="fas fa-cloud-sun"></i>
                        </div>
                        <div class="template-name">天气预报</div>
                        <div class="template-desc">本地天气和预报</div>
                    </div>
                    <div class="template-card" onclick="selectTemplate(this, 'memo')">
                        <div class="template-icon memo">
                            <i class="fas fa-edit"></i>
                        </div>
                        <div class="template-name">智能记事</div>
                        <div class="template-desc">AI 整理的文本便签</div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn secondary" onclick="closeModal('newStickyModal')">取消</button>
                <button class="btn primary" onclick="createSticky()" id="createBtn" disabled>创建</button>
            </div>
        </div>
    </div>

    <!-- 全局搜索 -->
    <div class="search-overlay" id="searchOverlay">
        <div class="search-box">
            <input type="text" class="search-input" placeholder="搜索便签..." onkeyup="searchStickies(this.value)">
            <div class="search-results" id="searchResults">
                <div class="search-item" onclick="focusSearchResult('crypto-sticky')">
                    <div class="search-item-icon" style="background: var(--warning);">
                        <i class="fab fa-bitcoin"></i>
                    </div>
                    <div class="search-item-info">
                        <div class="search-item-name">BTC/USDT</div>
                        <div class="search-item-desc">币价监控 · $67,842</div>
                    </div>
                    <div class="search-item-status" style="background: var(--accent);"></div>
                </div>
                <div class="search-item" onclick="focusSearchResult('stock-sticky')">
                    <div class="search-item-icon" style="background: var(--primary);">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <div class="search-item-info">
                        <div class="search-item-name">TSLA</div>
                        <div class="search-item-desc">股票监控 · $168.42</div>
                    </div>
                    <div class="search-item-status" style="background: var(--warning);"></div>
                </div>
                <div class="search-item" onclick="focusSearchResult('traffic-sticky')">
                    <div class="search-item-icon" style="background: var(--success);">
                        <i class="fas fa-route"></i>
                    </div>
                    <div class="search-item-info">
                        <div class="search-item-name">通勤路况</div>
                        <div class="search-item-desc">交通监控 · 25 分钟</div>
                    </div>
                    <div class="search-item-status"></div>
                </div>
                <div class="search-item" onclick="focusSearchResult('weather-sticky')">
                    <div class="search-item-icon" style="background: var(--purple);">
                        <i class="fas fa-cloud-sun"></i>
                    </div>
                    <div class="search-item-info">
                        <div class="search-item-name">北京天气</div>
                        <div class="search-item-desc">天气监控 · 22°C 晴朗</div>
                    </div>
                    <div class="search-item-status"></div>
                </div>
                <div class="search-item" onclick="focusSearchResult('memo-sticky')">
                    <div class="search-item-icon" style="background: var(--secondary);">
                        <i class="fas fa-edit"></i>
                    </div>
                    <div class="search-item-info">
                        <div class="search-item-name">会议记录</div>
                        <div class="search-item-desc">智能记事 · 产品评审会议</div>
